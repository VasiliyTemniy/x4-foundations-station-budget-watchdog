          $step = 1,
          $height = 'Helper.slidercellMinHeight',
          $start = player.entity.$vas_sbw_min_transfer_m,
          $suffix = ' M Cr',
          $onSliderCellConfirm = OnTuningChanged,
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col = 1, $colSpan = 2, $text = {202600608,45}, $halign = 'left']"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col = 3,
          $colSpan = 2,
          $id = 'vas_sbw_keep_player_m',
          $echo = 'vas_sbw_keep_player_m',
          $min = 0,
          $max = 500,
          $step = 5,
          $height = 'Helper.slidercellMinHeight',
          $start = player.entity.$vas_sbw_keep_player_m,
          $suffix = ' M Cr',
          $onSliderCellConfirm = OnTuningChanged,
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col = 1, $colSpan = 2, $text = {202600608,42}, $halign = 'left']"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
