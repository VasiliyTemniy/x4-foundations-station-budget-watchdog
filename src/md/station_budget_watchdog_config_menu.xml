    <cue name="ShowStatus" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <do_if value="not @player.entity.$vas_sbw_status_token">
          <set_value name="player.entity.$vas_sbw_status_token" exact="0"/>
        </do_if>
        <set_value name="player.entity.$vas_sbw_status_token" operation="add"/>
        <set_value name="$token" exact="player.entity.$vas_sbw_status_token"/>
        <set_value name="$text" exact="event.param.$text"/>
        <set_value name="$color" exact="if @event.param.$color then event.param.$color else 'Color.text_normal'"/>
        <set_value name="player.entity.$vas_sbw_status_text" exact="$text"/>
        <set_value name="player.entity.$vas_sbw_status_color" exact="$color"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Update_Widget" param="table[
          $id = 'vas_sbw_status',
          $text = $text,
          $color = $color,
        ]"/>
        <do_if value="not @event.param.$keep">
          <set_value name="player.entity.$vas_sbw_status_clear_token" exact="$token"/>
          <raise_lua_event name="'Time.setAlarm'" param="'vas_sbw_status_clear:3'"/>
        </do_if>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <cue name="ClearStatusAfterDelay" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'Time'" control="'vas_sbw_status_clear'"/>
      </conditions>
      <actions>
        <do_if value="player.entity.$vas_sbw_status_token == player.entity.$vas_sbw_status_clear_token">
          <set_value name="player.entity.$vas_sbw_status_text" exact="''"/>
          <set_value name="player.entity.$vas_sbw_status_color" exact="'Color.text_normal'"/>
          <signal_cue_instantly cue="md.Simple_Menu_API.Update_Widget" param="table[
            $id = 'vas_sbw_status',
            $text = '',
            $color = 'Color.text_normal',
          ]"/>
          <signal_cue_instantly cue="md.Simple_Menu_API.Refresh_Menu"/>
        </do_if>
        <remove_value name="player.entity.$vas_sbw_status_clear_token"/>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <cue name="OnToggleChanged" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$key" exact="@event.param.$echo"/>
        <do_if value="$key == 'vas_sbw_topup_enabled' or $key == 'vas_sbw_drain_enabled' or $key == 'vas_sbw_use_happy_station_texts' or $key == 'vas_sbw_debug_enabled'">
          <set_value name="player.entity.{'$' + $key}" exact="if event.param.$checked then true else false"/>
        </do_if>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <cue name="OnUseVanillaBudgetChanged" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <do_if value="not @player.entity.$vas_sbw_handle_all_stations">
          <set_value name="player.entity.$vas_sbw_use_vanilla_budget" exact="if event.param.$checked then true else false"/>
        </do_if>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <cue name="OnHandleAllStationsChanged" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="player.entity.$vas_sbw_handle_all_stations" exact="if event.param.$checked then true else false"/>
        <!-- Just rerender the menu to make the use_vanilla_budget checkbox inactive -->
        <signal_cue_instantly cue="md.Simple_Menu_API.Refresh_Menu"/>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <!-- One handler for all five tuning sliders; the echo names the entity var. -->
    <cue name="OnTuningChanged" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$key" exact="@event.param.$echo"/>
        <do_if value="$key == 'vas_sbw_check_interval' or $key == 'vas_sbw_min_transfer_m' or $key == 'vas_sbw_keep_player_m' or $key == 'vas_sbw_grant_pct' or $key == 'vas_sbw_drain_check_pct' or $key == 'vas_sbw_drain_leave_pct'">
          <set_value name="player.entity.{'$' + $key}" exact="event.param.$value"/>
        </do_if>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <cue name="OnNewTagChanged" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <do_if value="@player.entity.$vas_sbw_ignore_next_newtag_deactivate and event.param.$event == 'onEditBoxDeactivated'">
          <set_value name="player.entity.$vas_sbw_ignore_next_newtag_deactivate" exact="false"/>
        </do_if>
        <do_else>
          <set_value name="player.entity.$vas_sbw_newtag" exact="event.param.$text"/>
        </do_else>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <cue name="OnNewTargetChanged" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="player.entity.$vas_sbw_newtargetm" exact="event.param.$value"/>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <cue name="OnAddTag" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <do_if value="not @player.entity.$vas_sbw_targets">
          <set_value name="player.entity.$vas_sbw_targets" exact="[]"/>
        </do_if>
        <set_value name="$tag" exact="player.entity.$vas_sbw_newtag"/>
        <run_actions ref="TagClashes" result="$clash">
          <param name="Tag" value="$tag"/>
          <param name="List" value="player.entity.$vas_sbw_targets"/>
        </run_actions>
        <do_if value="$tag == ''">
          <signal_cue_instantly cue="ShowStatus" param="table[
            $text = {202600608,20},
            $color = 'Color.text_negative',
          ]"/>
        </do_if>
        <do_elseif value="$clash">
          <signal_cue_instantly cue="ShowStatus" param="table[
            $text = {202600608,21},
            $color = 'Color.text_negative',
          ]"/>
        </do_elseif>
        <do_else>
          <append_to_list name="player.entity.$vas_sbw_targets" exact="table[
            $tag = $tag,
            $target = player.entity.$vas_sbw_newtargetm * 1000000Cr,
          ]"/>
          <set_value name="player.entity.$vas_sbw_ignore_next_newtag_deactivate" exact="true"/>
          <set_value name="player.entity.$vas_sbw_newtag" exact="''"/>
          <signal_cue_instantly cue="ShowStatus" param="table[
            $text = {202600608,22},
            $color = 'Color.text_positive',
          ]"/>
          <signal_cue_instantly cue="md.Simple_Menu_API.Refresh_Menu"/>
        </do_else>
        <reset_cue cue="this"/>
      </actions>
    </cue>

    <cue name="OnRemoveTag" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$tag" exact="@event.param.$echo"/>
        <do_if value="@player.entity.$vas_sbw_targets and @$tag">
          <do_for_each name="$e" in="player.entity.$vas_sbw_targets" reverse="true">
            <do_if value="$e.$tag == $tag">
              <remove_from_list name="player.entity.$vas_sbw_targets" exact="$e"/>
              <signal_cue_instantly cue="ShowStatus" param="table[
                $text = {202600608,23},
                $color = 'Color.text_positive',
              ]"/>
            </do_if>
          </do_for_each>
        </do_if>
        <signal_cue_instantly cue="md.Simple_Menu_API.Refresh_Menu"/>
        <reset_cue cue="this"/>
      </actions>
    </cue>
  </cues>
</mdscript>
