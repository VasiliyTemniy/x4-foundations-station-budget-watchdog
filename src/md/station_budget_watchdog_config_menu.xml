          $col = 1,
          $colSpan = 4,
          $id = 'vas_sbw_newtag',
          $height = 'Helper.standardButtonHeight',
          $defaultText = if player.entity.$vas_sbw_newtag != '' then player.entity.$vas_sbw_newtag else {202600608,13},
