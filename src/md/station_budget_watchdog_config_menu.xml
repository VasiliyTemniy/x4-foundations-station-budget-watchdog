<?xml version="1.0" encoding="utf-8"?>
<mdscript name="VAS_StationBudgetWatchdog_Config"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>
    <!--@doc
        Idempotent defaults seeder: per-tag target list, feature toggles, menu
        scratch state and tuning knobs. All state lives on player.entity (the
        core watchdog script reads it there). String-coercion null checks:
        explicit false/0 must NOT be re-seeded; saved/edited values persist. -->
    <library name="SeedDefaults" purpose="run_actions">
      <actions>
        <do_if value="not @player.entity.$vas_sbw_targets">
          <set_value name="player.entity.$vas_sbw_targets" exact="[
            table[$tag = '[AB5]',  $target = 5000000Cr],
            table[$tag = '[AB10]', $target = 10000000Cr],
            table[$tag = '[AB20]', $target = 20000000Cr],
            table[$tag = '[AB40]', $target = 40000000Cr],
          ]"/>
        </do_if>
        <do_if value="not @player.entity.$vas_sbw_newtag">
          <set_value name="player.entity.$vas_sbw_newtag" exact="''"/>
        </do_if>
        <do_if value="not @player.entity.$vas_sbw_newtargetm">
          <set_value name="player.entity.$vas_sbw_newtargetm" exact="5"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_topup_enabled + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_topup_enabled" exact="true"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_drain_enabled + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_drain_enabled" exact="true"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_use_vanilla_budget + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_use_vanilla_budget" exact="false"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_handle_all_stations + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_handle_all_stations" exact="false"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_use_happy_station_texts + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_use_happy_station_texts" exact="false"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_debug_enabled + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_debug_enabled" exact="false"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_check_interval + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_check_interval" exact="30"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_min_transfer_m + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_min_transfer_m" exact="1"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_keep_player_m + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_keep_player_m" exact="20"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_grant_pct + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_grant_pct" exact="200"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_drain_check_pct + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_drain_check_pct" exact="300"/>
        </do_if>
        <do_if value="(@player.entity.$vas_sbw_drain_leave_pct + '') == 'null'">
          <set_value name="player.entity.$vas_sbw_drain_leave_pct" exact="150"/>
        </do_if>
      </actions>
    </library>

    <!-- event_universe_generated fires both at new-game start AND on every
         savegame load (md.xsd), so it alone covers all sessions. instantiate,
         not a plain cue: a plain cue would complete on its first-ever event
         and never seed again in that playthrough. -->
    <cue name="InitDefaults" instantiate="true">
      <conditions>
        <event_universe_generated/>
      </conditions>
      <actions>
        <run_actions ref="SeedDefaults"/>
      </actions>
    </cue>

    <!--@doc
        True if $Tag would clash with any tag already in $List under our substring
        match - i.e. either is a substring of the other (e.g. "[AB5]" inside "[AB5]0]").
        The Add handler calls this and rejects the new tag on a clash.
        Params: Tag - candidate tag string;  List - the targets list (table[$tag,...]).
        Returns: bool. -->
    <library name="TagClashes" purpose="run_actions">
      <params>
        <param name="Tag"/>
        <param name="List" default="[]"/>
      </params>
      <actions>
        <set_value name="$clash" exact="false"/>
        <do_for_each name="$e" in="$List">
          <set_value name="$a" exact="$Tag"/>
          <substitute_text text="$a"><replace string="$e.$tag" with="''"/></substitute_text>
          <set_value name="$b" exact="$e.$tag"/>
          <substitute_text text="$b"><replace string="$Tag" with="''"/></substitute_text>
          <do_if value="$a != $Tag or $b != $e.$tag">
            <set_value name="$clash" exact="true"/>
            <break/>
          </do_if>
        </do_for_each>
        <return value="$clash"/>
      </actions>
    </library>

    <!-- Register the config editor in Extension Options. -->
    <cue name="Register_Options_Menu" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Simple_Menu_Options.Reloaded"/>
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Simple_Menu_API.Register_Options_Menu" param="table[
          $id = 'vas_sbw_options_menu',
          $columns = 4,
          $title = {202600608,10},
          $onOpen = BuildWatchdogMenu,
        ]"/>
        <reset_cue cue="this"/>
      </actions>
    </cue>

